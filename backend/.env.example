# ==============================================================================
# Azure AD / Microsoft Identity Platform
# Obtenha esses valores no portal Azure > App registrations > sua aplicação
# ==============================================================================

# ID da aplicação registrada no Azure AD (Application (client) ID)
CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Segredo do cliente gerado em Certificates & secrets
CLIENT_SECRET=your-client-secret-value

# ID do tenant (Directory (tenant) ID) ou "common" para multi-tenant
TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URI de redirecionamento cadastrada no Azure AD (Authentication > Redirect URIs)
REDIRECT_URI=http://localhost:8000/auth/callback/

# ==============================================================================
# Django
# ==============================================================================

# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-in-production

DEBUG=True

# Hosts permitidos separados por vírgula
ALLOWED_HOSTS=localhost,127.0.0.1

# ==============================================================================
# CORS (origens permitidas para o frontend)
# ==============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==============================================================================
# Banco de dados (padrão: SQLite para desenvolvimento)
# Para PostgreSQL: postgresql://user:password@localhost:5432/dbname
# ==============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/bsoft_auth
